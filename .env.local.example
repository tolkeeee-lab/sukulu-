# ============================================================
# SUKULU - Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS commiter .env.local !
# ============================================================

# --- SUPABASE ---
# URL de votre projet Supabase (visible dans Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clé publique anon — safe côté client (lecture restreinte par RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ Clé privée service_role — UNIQUEMENT côté serveur (Server Actions, API Routes)
# Ne jamais exposer dans le navigateur ni dans des variables NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# --- CINETPAY (Paiements Mobile Money + SMS OTP) ---
# Clé API de votre compte CinetPay
CINETPAY_API_KEY=

# Identifiant de site CinetPay
CINETPAY_SITE_ID=

# Clé secrète pour valider les webhooks entrants (signature HMAC)
CINETPAY_SECRET_KEY=

# URL de callback webhook après un paiement (doit être accessible publiquement)
CINETPAY_NOTIFY_URL=

# --- FEDAPAY (Optionnel — passerelle de paiement Bénin/Togo) ---
# Clé secrète FedaPay (côté serveur uniquement)
FEDAPAY_SECRET_KEY=

# Clé publique FedaPay (côté client)
FEDAPAY_PUBLIC_KEY=

# --- KKIAPAY (Optionnel — paiement Mobile Money Afrique de l'Ouest) ---
# Clé publique KKiaPay
KKIAPAY_PUBLIC_KEY=

# Clé privée KKiaPay (côté serveur uniquement)
KKIAPAY_PRIVATE_KEY=

# Clé secrète KKiaPay pour la validation des webhooks
KKIAPAY_SECRET=

# --- APPLICATION ---
# URL publique de l'application (sans slash final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nom affiché de l'application
NEXT_PUBLIC_APP_NAME=Sukulu

# Environnement d'exécution : development | production | test
NODE_ENV=development
